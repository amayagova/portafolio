---
import { Icon } from "astro-icon/components";

const skills = [
  { name: "HTML / CSS", level: 90, icon: "simple-icons:html5" },
  { name: "JavaScript", level: 85, icon: "simple-icons:javascript" },
  { name: "TypeScript", level: 75, icon: "simple-icons:typescript" },
  { name: "React", level: 80, icon: "simple-icons:react" },
  { name: "Next.js", level: 75, icon: "simple-icons:nextdotjs" },
  { name: "Astro", level: 70, icon: "simple-icons:astro" },
  { name: "Node.js", level: 75, icon: "simple-icons:nodedotjs" },
  { name: "Python", level: 70, icon: "simple-icons:python" },
  { name: "Kotlin", level: 60, icon: "simple-icons:kotlin" },
  { name: "SQL / SQLite", level: 70, icon: "simple-icons:sqlite" },
  { name: "Tailwind CSS", level: 75, icon: "simple-icons:tailwindcss" },
  { name: "Git", level: 80, icon: "simple-icons:git" },
];
---

<section class="section" id="skills">
  <div class="container">
    <h2 class="section-title animate-on-scroll">Mis <span>Habilidades</span></h2>
    <div class="skills-grid">
      {skills.map((skill, i) => (
        <div class="skill-item animate-on-scroll" data-delay={i + 1}>
          <div class="skill-header">
            <span class="skill-name">
              <Icon name={skill.icon} class="skill-icon" />
              {skill.name}
            </span>
            <span class="skill-level">{skill.level}%</span>
          </div>
          <div class="skill-bar">
            <div class="skill-fill" style={`width: ${skill.level}%`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .skill-name {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .skill-icon {
    width: 22px;
    height: 22px;
    color: var(--accent);
    flex-shrink: 0;
  }

  .skill-level {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }

  .skill-bar {
    height: 8px;
    background: var(--border);
    border-radius: 999px;
    overflow: hidden;
  }

  .skill-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-hover));
    border-radius: 999px;
    width: 0;
    transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .skill-item.is-visible .skill-fill {
    animation: fillBar 0.8s 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
</style>
